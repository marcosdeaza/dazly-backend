# ========================================
# 🔧 DAZLY API - PLANTILLA DE VARIABLES
# ========================================
# Copia este archivo como .env y completa los valores
# Para producción, usa .env.production
# ========================================

# ============================================
# 🗄️ BASE DE DATOS
# ============================================
DATABASE_URL="postgresql://username:password@localhost:5432/dazly_db"

# ============================================
# 🔐 JWT & SEGURIDAD
# ============================================
JWT_SECRET="tu-secreto-jwt-minimo-32-caracteres-aqui"
JWT_EXPIRES_IN="7d"

# ============================================
# 🌐 FRONTEND & CORS
# ============================================
FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# ============================================
# ⚙️ SERVIDOR
# ============================================
PORT=8081
NODE_ENV="development"

# ============================================
# 🔑 GOOGLE OAUTH 2.0
# ============================================
GOOGLE_CLIENT_ID="tu-google-client-id"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:8081/api/auth/google/callback"

# ============================================
# ☁️ GOOGLE CLOUD / VERTEX AI
# ============================================
GOOGLE_CLOUD_PROJECT_ID="tu-project-id"
VERTEX_AI_LOCATION="europe-southwest1"
GEMINI_MODEL="gemini-2.5-flash-image"

# ============================================
# 💳 STRIPE
# ============================================
STRIPE_SECRET_KEY="sk_test_tu_clave_aqui"
STRIPE_PUBLISHABLE_KEY="pk_test_tu_clave_aqui"
STRIPE_WEBHOOK_SECRET="whsec_tu_webhook_secret"

# ============================================
# 💰 STRIPE PRICE IDs
# ============================================
STRIPE_XMAS_PRICE_ID="price_1XMS000"
STRIPE_PULSE_PRICE_ID="price_1ABC123"
STRIPE_FLOW_PRICE_ID="price_1DEF456"
STRIPE_SUMMIT_PRICE_ID="price_1GHI789"
STRIPE_PEAK_PRICE_ID="price_1JKL012"
STRIPE_INFINITY_PRICE_ID="price_1MNO345"