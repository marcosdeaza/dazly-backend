# BACKUP DEL .env.example ANTIGUO
# Este archivo se mantiene como referencia histórica

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/dazly_db"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-here-min-32-chars"
JWT_EXPIRES_IN="7d"

# Frontend Configuration
FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# Server Configuration
PORT=8081
NODE_ENV="development"

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Stripe Price IDs (crear en Stripe Dashboard)
STRIPE_PULSE_PRICE_ID="price_1ABC123def456GHI"
STRIPE_FLOW_PRICE_ID="price_1DEF789ghi012JKL"
STRIPE_SUMMIT_PRICE_ID="price_1GHI345jkl678MNO"
STRIPE_PEAK_PRICE_ID="price_1JKL901mno234PQR"
STRIPE_INFINITY_PRICE_ID="price_1MNO567pqr890STU"

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT_ID="your-project-id"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"
VERTEX_AI_LOCATION="us-central1"

# Optional: OAuth Configuration
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
